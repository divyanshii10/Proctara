# ===========================================
# Proctara Environment Configuration
# Copy this to .env and fill in values
# ===========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proctara?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI — Groq (OpenAI-compatible API)
GROQ_API_KEY=""

# Email Service (for future use)
EMAIL_SERVICE=""
EMAIL_SERVICE_PASSCODE=""

# AWS S3 (for reports, recordings, resumes)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="proctara-uploads"

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000
API_URL="http://localhost:3001"

# Upload Directory (local dev — production uses S3)
UPLOAD_DIR="./uploads"
